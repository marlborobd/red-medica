# ============================================================
# Red Medica - Asistență Medicală la Domiciliu
# Variabile de mediu necesare pentru deployment
# Copiați acest fișier în .env și completați valorile
# ============================================================

# ----- Server -----
# Portul pe care rulează backend-ul (Railway îl setează automat)
PORT=5000

# Mediul de execuție: development | production
NODE_ENV=production

# ----- Securitate JWT -----
# Cheie secretă pentru semnarea token-urilor JWT
# IMPORTANT: Schimbați cu o valoare aleatorie lungă în producție!
# Generați cu: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=schimbati_cu_o_cheie_secreta_lunga_si_aleatorie_min_64_caractere

# ----- Baza de date SQLite -----
# Calea către fișierul SQLite
# Pe Railway: adăugați un Volume montat la /data și setați această variabilă
# Fără volume: DB se resetează la fiecare restart!
DATABASE_PATH=/data/asistenta.db

# ----- CORS -----
# Originea permisă pentru cereri cross-origin (în dev, frontend-ul React)
# În producție pe Railway: nu este necesar (frontend servit din același server)
# CORS_ORIGIN=http://localhost:3000

# ----- Cloudinary (poze rețete) -----
# Creați cont gratuit pe https://cloudinary.com
# Copiați Cloud Name, API Key și API Secret din dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ----- Google Drive Backup -----
# Creați un Service Account în Google Cloud Console
# Activați Google Drive API, descărcați JSON-ul cu cheile
# Copiați întregul conținut JSON ca string pe o singură linie
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"..."}
# ID-ul folderului Google Drive unde se salvează backup-urile
# Partajați folderul cu email-ul Service Account-ului (Editor)
GOOGLE_DRIVE_FOLDER_ID=your_folder_id

# ----- OneSignal Push Notifications -----
# App ID din OneSignal Dashboard > Settings > Keys & IDs
# IMPORTANT: variabilele REACT_APP_ trebuie setate în Railway ca Build Variables
# (nu doar Runtime Variables) pentru ca React să le includă în bundle la build time
REACT_APP_ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_API_KEY=your_onesignal_rest_api_key

# ----- Admin implicit -----
# Userul admin se creează automat la primul start dacă nu există
# Schimbați parola după primul login!
ADMIN_EMAIL=admin@asistenta.ro
ADMIN_PASSWORD=Admin123!
ADMIN_NAME=Administrator
